{
  "name": "@dimes-fi/multiply-sdk",
  "version": "0.4.2",
  "description": "TypeScript SDK for the Dimes Multiply leverage protocol on prediction markets",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "dimes",
    "multiply",
    "prediction-markets",
    "leverage",
    "polymarket",
    "defi",
    "trading",
    "sdk"
  ],
  "author": "Dimes <dev@dimes.fi> (https://dimes.fi)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dimes-fi/multiply-sdk"
  },
  "homepage": "https://docs.dimes.fi/sdk",
  "bugs": {
    "url": "https://github.com/dimes-fi/multiply-sdk/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "ethers": "^6.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.2",
    "vitest": "^1.1.0"
  }
}
